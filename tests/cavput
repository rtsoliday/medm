#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"

resolve_cavput() {
  local candidate="${1:-}"

  if [[ -z "${candidate}" || ! -x "${candidate}" ]]; then
    return 1
  fi

  if [[ "$(readlink -f "${candidate}")" == "${SCRIPT_PATH}" ]]; then
    return 1
  fi

  printf '%s\n' "${candidate}"
}

if [[ -n "${CAVPUT_REAL_BIN:-}" ]]; then
  exec "${CAVPUT_REAL_BIN}" "$@"
fi

candidate="$(command -v cavput 2>/dev/null || true)"
if resolved="$(resolve_cavput "${candidate}")"; then
  exec "${resolved}" "$@"
fi

if resolved="$(resolve_cavput "/usr/local/oag/apps/bin/linux-x86_64/cavput")"; then
  exec "${resolved}" "$@"
fi

echo "cavput binary not found. Set CAVPUT_REAL_BIN to an installed cavput executable." >&2
exit 127
