[
  {
    "name": "text_monitor_live_string_update",
    "display": "tests/test_TextMonitor.adl",
    "selector": {
      "type": "text_monitor",
      "channel": "tm:string:status",
      "geometry": {
        "x": 1140,
        "y": 206,
        "width": 250,
        "height": 12
      }
    },
    "exit_after_ms": 4500,
    "writes": [
      {
        "pv": "tm:string:status",
        "value": "ACTIVE"
      }
    ],
    "expect": {
      "connected": true,
      "initial_update": true,
      "display_text": "ACTIVE",
      "string_value": "ACTIVE"
    }
  },
