[
  {
    "name": "text_monitor_live_string_update",
    "display": "tests/test_TextMonitor.adl",
    "selector": {
      "type": "text_monitor",
      "channel": "tm:string:status"
    },
    "post_ready_delay_ms": 1000,
    "exit_after_ms": 4500,
    "writes": [
      {
        "pv": "tm:string:status",
        "value": "ACTIVE"
      }
    ],
    "expect": {
      "connected": true,
      "initial_update": true,
      "display_text": "ACTIVE",
      "string_value": "ACTIVE"
    }
  },
  {
    "name": "slider_live_numeric_update",
    "display": "tests/test_Slider.adl",
    "selector": {
      "type": "slider",
      "channel": "slider:test:alpha"
    },
    "post_ready_delay_ms": 1000,
    "exit_after_ms": 4500,
    "writes": [
      {
        "pv": "slider:test:alpha",
        "value": "33.75"
      }
    ],
    "expect": {
      "connected": true,
      "initial_update": true,
      "write_access": true,
      "numeric_value": 33.75,
      "numeric_tolerance": 0.000001
    }
  },
  {
    "name": "meter_live_numeric_update",
    "display": "tests/test_Meter.adl",
    "selector": {
      "type": "meter",
      "channel": "meter:fast:alpha"
    },
    "post_ready_delay_ms": 1000,
    "exit_after_ms": 4500,
    "writes": [
      {
        "pv": "meter:fast:alpha",
        "value": "77.5"
      }
    ],
    "expect": {
      "connected": true,
      "initial_update": true,
      "numeric_value": 77.5,
      "numeric_tolerance": 0.000001
    }
  }
]
