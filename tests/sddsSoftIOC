#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"

resolve_ioc() {
  local candidate="${1:-}"

  if [[ -z "${candidate}" || ! -x "${candidate}" ]]; then
    return 1
  fi

  if [[ "$(readlink -f "${candidate}")" == "${SCRIPT_PATH}" ]]; then
    return 1
  fi

  printf '%s\n' "${candidate}"
}

if [[ -n "${SDDS_SOFT_IOC_REAL_BIN:-}" ]]; then
  exec "${SDDS_SOFT_IOC_REAL_BIN}" "$@"
fi

candidate="$(command -v sddsSoftIOC 2>/dev/null || true)"
if resolved="$(resolve_ioc "${candidate}")"; then
  exec "${resolved}" "$@"
fi

if resolved="$(resolve_ioc "/usr/local/oag/apps/bin/linux-x86_64/sddsSoftIOC")"; then
  exec "${resolved}" "$@"
fi

echo "sddsSoftIOC binary not found. Set SDDS_SOFT_IOC_REAL_BIN to an installed sddsSoftIOC executable." >&2
exit 127
